# ============================================================
#  Unity .gitignore  —  VR project
#  Commit only:  Assets/   Packages/   ProjectSettings/
#  Everything below is generated locally and is rebuilt
#  automatically when the project is opened.
# ============================================================

# Unity-generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
.utmp/

# Build artifacts (APKs and their debug-symbol folders)
*.apk
*.aab
*.app
*.unitypackage
*_BackUpThisFolder_ButDontShipItWithYourGame/
*_BurstDebugInformation_DoNotShip/

# Auto-generated IDE / solution / project files
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
ExportedObj/

# Editor & OS files
.vs/
.vscode/
.idea/
.gradle/
.DS_Store
Thumbs.db
sysinfo.txt
*.stackdump
crashlytics-build.properties

# Never ignore .meta files — they link your assets together
!**/*.meta
